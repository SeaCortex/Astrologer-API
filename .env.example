# ============================================
# Astrologer API - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# The .env file is ignored by git (see .gitignore).

# --------------------------------------------
# Environment Type
# --------------------------------------------
# Controls which TOML configuration file is loaded.
# Valid values: "dev", "test", "production"
# If not set, defaults to production config.
ENV_TYPE=dev

# --------------------------------------------
# API Secret Keys
# --------------------------------------------
# Used for proxy authentication when debug=False (production mode).
# These must match the secret values sent by your API proxies
# in the X-RapidAPI-Proxy-Secret and X-AstrologerStudio-Proxy-Secret headers.

# RapidAPI Proxy Secret Key
RAPID_API_SECRET_KEY=

# Astrologer Studio Proxy Secret Key
ASTROLOGER_STUDIO_SECRET_KEY=
